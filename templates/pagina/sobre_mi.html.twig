{# templates/pagina/sobre_mi.html.twig #}
{% extends 'base.html.twig' %}

{% block titulo %}Sobre mí{% endblock %}

{% block contenido %}
    <h2>Mis habilidades</h2>
    <p style="color: #666; margin-bottom: 25px;">A lo largo de mi carrera he desarrollado competencias técnicas en diversas tecnologías de desarrollo web.</p>

    {# habilidades es array asociativo: clave = nombre, valor = porcentaje #}
    {% for habilidad, nivel in habilidades %}
        <div style="margin-bottom: 20px;">
            <div style="display:flex; justify-content:space-between; margin-bottom: 8px;">
                <span style="font-weight:600; color:#2c3e50;">{{ habilidad }}</span>
                <span style="font-size:0.85rem; color:#7f8c8d;">{{ nivel }}%</span>
            </div>
            <div style="background:#ecf0f1; border-radius:10px; height:12px; overflow: hidden;">
                <div style="background: linear-gradient(90deg, #3498db, #2980b9); width:{{ nivel }}%; height:100%; border-radius:10px; transition: width 1s ease-in-out;"></div>
            </div>
        </div>
    {% endfor %}

    <div style="margin-top: 40px; padding: 25px; background: #f9f9f9; border-left: 5px solid #3498db; border-radius: 4px;">
        <h3 style="margin-top: 0; color: #2c3e50;">Mi Motivación</h3>
        <p style="line-height: 1.6; color: #555;">
            Mi objetivo es convertirme en un arquitecto de software capaz de diseñar sistemas escalables y eficientes. 
            Me apasiona aprender nuevas tecnologías y enfrentar desafíos que me permitan crecer profesionalmente 
            en el ecosistema de PHP y sus frameworks modernos.
        </p>
    </div>
{% endblock %}
