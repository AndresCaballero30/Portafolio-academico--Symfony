{# templates/pagina/sobre_mi.html.twig #}
{% extends 'base.html.twig' %}

{% block titulo %}Sobre mí{% endblock %}

{% block contenido %}
    <h2>Mis habilidades</h2>

    {# habilidades es array asociativo: clave = nombre, valor = porcentaje #}
    {% for habilidad, nivel in habilidades %}
        <div style="margin-bottom: 12px;">
            <div style="display:flex; justify-content:space-between;">
                <span style="font-weight:600; color:#1a3c5e;">{{ habilidad }}</span>
                <span style="font-size:0.85rem; color:#666;">{{ nivel }}%</span>
            </div>
            <div style="background:#e0e0e0; border-radius:4px; height:8px;">
                <div style="background:#1a3c5e; width:{{ nivel }}%; height:100%; border-radius:4px;"></div>
            </div>
        </div>
    {% endfor %}
{% endblock %}
