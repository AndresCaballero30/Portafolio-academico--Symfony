{# templates/pagina/sobre_mi.html.twig #}
{% extends 'base.html.twig' %}

{% block titulo %}Sobre mí{% endblock %}

{% block contenido %}
    <div class="profile-container">
        <div class="profile-image">
            <div class="photo-container">
                <img src="{{ asset('images/perfil.png') }}" alt="Foto de {{ profile_name|default('Andrés Caballero') }}" class="profile-photo">
            </div>
        </div>
        <div class="profile-info">
            <h2 class="profile-name">Andres Benjamin Caballero Basagoitia</h2>
            <p class="profile-career">Ingenieria en sistemas</p>
            <p class="profile-university">Universidad San Francisco de Asis - Sede La Paz</p>
            
            <div class="motivation-section-inline">
                <h3 class="motivation-title">Mi Motivación</h3>
                <p class="motivation-text">
                    Mi objetivo es convertirme en un arquitecto de software capaz de diseñar sistemas escalables y eficientes. 
                    Me apasiona aprender nuevas tecnologías y enfrentar desafíos que me permitan crecer profesionalmente 
                    en el ecosistema de PHP y sus frameworks modernos.
                </p>
            </div>
        </div>
    </div>

    <h2>Mis habilidades</h2>
    <p class="skills-description">A lo largo de mi carrera he desarrollado competencias técnicas en diversas tecnologías de desarrollo web.</p>

    <div class="skills-grid">
        {% for habilidad_obj in habilidades %}
            <div class="skill-card">
                <div class="skill-header">
                    <span class="skill-name">{{ habilidad_obj.nombre }}</span>
                    <span class="skill-percentage">{{ habilidad_obj.nivelFormateado }}</span>
                </div>
                <div class="skill-bar-background">
                    <div class="skill-progress-fill" style="width:{{ habilidad_obj.nivel }}%;"></div>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="suggestion-box">
        <h4>¿Qué otra habilidad técnica me recomendarías aprender?</h4>
        
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <form action="{{ path('app_sobre_mi') }}" method="POST" class="suggestion-form">
            <input type="text" name="sugerencia" placeholder="Ej: React, Docker, Python..." class="suggestion-input" required>
            <button type="submit" class="btn-secondary">Enviar sugerencia</button>
        </form>
    </div>
{% endblock %}
