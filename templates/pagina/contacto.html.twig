{# templates/pagina/contacto.html.twig #}
{% extends 'base.html.twig' %}

{% block titulo %}Contacto{% endblock %}

{% block contenido %}
    <h2>Formulario de Contacto</h2>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}
    
    <p class="demo-notice">
        ⚠ Este formulario es demostrativo. En Symfony el procesamiento requiere el Form Component.
    </p>

    <form action="#" method="POST" class="contact-form">
        <div class="form-group">
            <label>Nombre completo</label>
            <input type="text" name="nombre" placeholder="Andrés Caballero" class="form-control">
        </div>
        <div class="form-group">
            <label>Correo electrónico</label>
            <input type="email" name="email" placeholder="andres@ejemplo.com" class="form-control">
        </div>
        <div class="form-group">
            <label>Teléfono de contacto</label>
            <input type="tel" name="telefono" placeholder="+591 70000000" class="form-control">
        </div>
        <div class="form-group">
            <label>Tu mensaje</label>
            <textarea name="mensaje" rows="4" placeholder="¿En qué puedo ayudarte?" class="form-control text-area"></textarea>
        </div>
        <button type="submit" class="btn-submit">
            Enviar Mensaje de Contacto
        </button>
    </form>
{% endblock %}
