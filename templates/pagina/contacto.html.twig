{# templates/pagina/contacto.html.twig #}
{% extends 'base.html.twig' %}

{% block titulo %}Contacto{% endblock %}

{% block contenido %}
    <h2>Formulario de Contacto</h2>
    <p style="background:#fff3cd; border:1px solid #ffc107; padding:12px; border-radius:6px; color:#856404; font-size:14px;">
        ⚠ Este formulario es demostrativo. En Symfony el procesamiento requiere el Form Component.
    </p>

    <form action="#" method="POST" style="max-width:550px; margin-top:30px; background: #fff; padding: 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
        <div style="margin-bottom:20px;">
            <label style="display:block; font-weight:600; color:#2c3e50; margin-bottom:8px; font-size:0.9rem;">Nombre completo</label>
            <input type="text" name="nombre" placeholder="Andrés Caballero" style="width:100%; padding:12px 16px; border:2px solid #edf2f7; border-radius:8px; font-size:15px; outline: none; transition: border-color 0.3s;">
        </div>
        <div style="margin-bottom:20px;">
            <label style="display:block; font-weight:600; color:#2c3e50; margin-bottom:8px; font-size:0.9rem;">Correo electrónico</label>
            <input type="email" name="email" placeholder="andres@ejemplo.com" style="width:100%; padding:12px 16px; border:2px solid #edf2f7; border-radius:8px; font-size:15px; outline: none;">
        </div>
        <div style="margin-bottom:20px;">
            <label style="display:block; font-weight:600; color:#2c3e50; margin-bottom:8px; font-size:0.9rem;">Teléfono de contacto</label>
            <input type="tel" name="telefono" placeholder="+591 70000000" style="width:100%; padding:12px 16px; border:2px solid #edf2f7; border-radius:8px; font-size:15px; outline: none;">
        </div>
        <div style="margin-bottom:25px;">
            <label style="display:block; font-weight:600; color:#2c3e50; margin-bottom:8px; font-size:0.9rem;">Tu mensaje</label>
            <textarea name="mensaje" rows="4" placeholder="¿En qué puedo ayudarte?" style="width:100%; padding:12px 16px; border:2px solid #edf2f7; border-radius:8px; font-size:15px; outline: none; resize: vertical; min-height: 120px;"></textarea>
        </div>
        <button type="submit" style="background: linear-gradient(135deg, #3498db, #2c3e50); color:white; padding:14px 35px; border:none; border-radius:30px; cursor:pointer; font-size:16px; font-weight:600; width: 100%; box-shadow: 0 4px 10px rgba(52, 152, 219, 0.3); transition: transform 0.2s;">
            Enviar Mensaje de Contacto
        </button>
    </form>
{% endblock %}
