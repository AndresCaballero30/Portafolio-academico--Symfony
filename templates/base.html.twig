{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block titulo %}Mi Aplicación{% endblock %}</title>
    <style>
        body   { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; max-width: 1000px; margin: 0 auto; padding: 0; background-color: #f4f7f6; color: #333; }
        header { background: #2c3e50; color: white; padding: 25px 40px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        h1     { margin: 0; font-size: 1.5rem; letter-spacing: 1px; }
        nav a  { color: #ecf0f1; text-decoration: none; margin-left: 25px; font-weight: 500; transition: color 0.3s; }
        nav a:hover { color: #3498db; }
        main   { padding: 40px; background: white; margin-top: 20px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); min-height: 400px; }
        table  { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: none; padding: 15px; text-align: left; border-bottom: 1px solid #eee; }
        th     { background: #34495e; color: white; text-transform: uppercase; font-size: 0.8rem; }
        footer { background: #2c3e50; color: #bdc3c7; text-align: center; padding: 20px; margin-top: 50px; font-size: 0.9rem; }
    </style>
</head>
<body>
    <header>
        <h1>Portafolio Académico</h1>
        <nav>
            <a href="{{ path('app_inicio') }}">Inicio</a>
            <a href="{{ path('app_sobre_mi') }}">Sobre mí</a>
            <a href="{{ path('app_materias') }}">Materias</a>
            <a href="{{ path('app_contacto') }}">Contacto</a>
        </nav>
    </header>

    <main>
        {% block contenido %}{% endblock %}
    </main>

    <footer>
        <p>&copy; {{ 'now'|date('Y') }} — Symfony</p>
    </footer>
</body>
</html>
